---
import { SEO } from 'astro-seo';
import OrganizationSchema from '../components/seo/OrganizationSchema.astro';
import '../styles/global.css';
import '../styles/splash.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Solo technical consultancy out of Lexington, KY. Full site shipping Q3 2026. Email is the front door — wes@infiniteroomlabs.com.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      openGraph={{
        basic: {
          title,
          type: 'website',
          image: '/favicon.svg',
          url: canonical,
        },
        optional: { siteName: 'Infinite Room Labs', description },
      }}
    />
    <OrganizationSchema />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>
