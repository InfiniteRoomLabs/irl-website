---
interface FooterLink {
  href: string;
  label: string;
}

interface Props {
  sitemapLinks?: FooterLink[];
  showSitemap?: boolean;
  showLegal?: boolean;
}

const {
  sitemapLinks = [],
  showSitemap = sitemapLinks.length > 0,
  showLegal = false,
} = Astro.props;
---
<footer class="s-footer">
  <div class="s-footer__bar"></div>
  <div
    class="s-footer__inner"
    style={!showSitemap && !showLegal ? 'grid-template-columns: 1.3fr 1fr;' : ''}
  >
    <div>
      <div class="s-footer__brand-mark">Infinite<br />Room Labs</div>
      <div class="s-footer__brand-tag">Automate all the things.</div>
      <p class="s-footer__brand-quote">
        Solo technical consultancy. Kentucky LLC. Remote-first, Eastern Time. Paid discovery, written milestones, you own everything.
      </p>
    </div>

    {showSitemap && (
      <div>
        <h2 class="s-footer__head">Sitemap</h2>
        <ul class="s-footer__list">
          {sitemapLinks.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>
    )}

    <div>
      <h2 class="s-footer__head">Contact</h2>
      <ul class="s-footer__list">
        <li><a class="mono" href="mailto:wes@infiniteroomlabs.com">wes@infiniteroomlabs.com</a></li>
        <li><a class="mono" href="https://github.com/InfiniteRoomLabs">github.com/InfiniteRoomLabs</a></li>
      </ul>
    </div>

    {showLegal && (
      <div>
        <h2 class="s-footer__head">Legal</h2>
        <ul class="s-footer__list">
          <li><a href="#">Privacy Policy</a></li>
          <li><a href="#">Terms of Service</a></li>
          <li class="mono" style="color: var(--fg-muted); font-size: 12px; margin-top: 8px;">
            Infinite Room Labs LLC<br />Kentucky · est. 2026
          </li>
        </ul>
      </div>
    )}
  </div>
  <div class="s-footer__fine">
    <span>© 2026 Infinite Room Labs LLC · Automate all the things.</span>
    <span>Built in Lexington, KY</span>
  </div>
</footer>
