---
import ThresholdMark from './ThresholdMark.astro';

interface Props {
  markSize?: number;
  compact?: boolean;
  class?: string;
}

const { markSize = 22, compact = false, class: className = '' } = Astro.props;
---
<span
  class:list={[
    'inline-flex items-center gap-3 font-display font-normal text-lg uppercase leading-none text-fg-1',
    'tracking-eyebrow',
    className,
  ]}
>
  <ThresholdMark size={markSize} />
  <span class="whitespace-nowrap">{compact ? 'IRL' : 'Infinite Room Labs'}</span>
</span>
