---
import type { WithContext, ProfessionalService } from 'schema-dts';

const schema: WithContext<ProfessionalService> = {
    '@context': 'https://schema.org',
    '@type': ['LocalBusiness', 'ProfessionalService'],
    '@id': 'https://infiniteroomlabs.com/#organization',
    name: 'Infinite Room Labs',
    legalName: 'Infinite Room Labs LLC',
    url: 'https://infiniteroomlabs.com',
    description: 'Solo technical consultancy. Legacy modernization, CI/CD rescue, infrastructure as code, MSP integration, agentic AI infrastructure. Scoped before building; client owns everything on completion.',
    founder: { '@type': 'Person', name: 'Wes Gilleland' },
    address: {
        '@type': 'PostalAddress',
        addressLocality: 'Lexington',
        addressRegion: 'KY',
        addressCountry: 'US',
    },
    areaServed: 'Worldwide',
    priceRange: '$$',
    contactPoint: {
        '@type': 'ContactPoint',
        email: 'hello@infiniteroomlabs.com',
        contactType: 'sales',
        availableLanguage: 'English',
    },
    knowsAbout: [
        'Legacy system modernization',
        'CI/CD pipeline rescue',
        'Infrastructure as code',
        'MSP integration consulting',
        'Agentic AI infrastructure',
        'Technical discovery and scoping',
        'Software architecture and DevOps',
    ],
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
