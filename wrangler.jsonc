{
	"compatibility_date": "2026-05-03",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "irl-website",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{ "pattern": "infiniteroomlabs.com", "custom_domain": true },
		{ "pattern": "www.infiniteroomlabs.com", "custom_domain": true }
	]
}